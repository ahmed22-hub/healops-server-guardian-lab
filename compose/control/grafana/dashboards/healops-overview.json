{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "CPU Usage %",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Usage %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Disk Usage %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Incidents",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "healops_incidents_total"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU History",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory History",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"demo-web\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"demo-web\"}[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[1m])"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total[1m])"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["healops", "devops", "monitoring"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "",
  "title": "HealOps Professional Dashboard",
  "version": 2
}

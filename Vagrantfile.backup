# HealOps Server Guardian Lab
# Requirements on host: Vagrant + VirtualBox
# Usage: vagrant up

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.boot_timeout = 900

  config.vm.define "control" do |control|
    control.vm.hostname = "healops-control"

    control.vm.network "private_network", ip: "192.168.56.10", virtualbox__intnet: "healopsnet"
    control.vm.network "forwarded_port", guest: 3000, host: 3000, auto_correct: true
    control.vm.network "forwarded_port", guest: 9090, host: 9090, auto_correct: true
    control.vm.network "forwarded_port", guest: 5000, host: 5000, auto_correct: true

    control.vm.provider "virtualbox" do |vb|
      vb.name = "healops-control"
      vb.cpus = 2
      vb.memory = 2048
    end

    control.vm.provision "shell", path: "scripts/provision_common.sh"
    control.vm.provision "shell", path: "scripts/provision_control.sh"
  end

  config.vm.define "node1" do |node|
    node.vm.hostname = "healops-node1"

    node.vm.network "private_network", ip: "192.168.56.11", virtualbox__intnet: "healopsnet"
    node.vm.network "forwarded_port", guest: 80, host: 8088, auto_correct: true

    node.vm.provider "virtualbox" do |vb|
      vb.name = "healops-node1"
      vb.cpus = 2
      vb.memory = 2048
    end

    node.vm.provision "shell", path: "scripts/provision_common.sh"
    node.vm.provision "shell", path: "scripts/provision_node.sh"
  end
end